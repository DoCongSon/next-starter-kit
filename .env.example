# ==============================================================================
# ARCADIA STARTER - CONFIGURATION TEMPLATE
# ==============================================================================
# Sao chép tệp tin này thành tệp tin '.env' hoặc '.env.local' ở máy local và điền
# giá trị thực tế của bạn. KHÔNG ĐƯỢC COMMIT tệp tin '.env' thực tế lên GitHub.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Cấu hình Môi trường ứng dụng (App Environment)
# ------------------------------------------------------------------------------
# Môi trường chạy ứng dụng: 'development', 'production', hoặc 'test'.
# Mặc định ở máy local là 'development'.
NODE_ENV=development

# ------------------------------------------------------------------------------
# 2. Đường dẫn Ứng dụng (App URL)
# ------------------------------------------------------------------------------
# URL cơ sở của trang web của bạn (sử dụng ở cả Client và Server).
# Sử dụng 'http://localhost:3000' khi chạy local dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# 3. [Tùy chọn] Cấu hình bổ sung (Ví dụ Database ORM)
# ------------------------------------------------------------------------------
# DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"
